{
  "name": "cc-terminal-center",
  "productName": "Claude Code Terminal Center",
  "version": "0.4.0",
  "private": true,
  "description": "Claude Code Terminal Command Center — multi-project terminal hub",
  "author": "grebmann",
  "homepage": "https://github.com/grebmann1/command-center",
  "main": "out/main/index.js",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild": "electron-rebuild -f -w node-pty",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "@codingame/monaco-vscode-api": "^33.0.9",
    "@codingame/monaco-vscode-base-service-override": "^33.0.9",
    "@codingame/monaco-vscode-configuration-service-override": "^33.0.9",
    "@codingame/monaco-vscode-dialogs-service-override": "^33.0.9",
    "@codingame/monaco-vscode-editor-service-override": "^33.0.9",
    "@codingame/monaco-vscode-environment-service-override": "^33.0.9",
    "@codingame/monaco-vscode-explorer-service-override": "^33.0.9",
    "@codingame/monaco-vscode-extension-api": "^33.0.9",
    "@codingame/monaco-vscode-extensions-service-override": "^33.0.9",
    "@codingame/monaco-vscode-files-service-override": "^33.0.9",
    "@codingame/monaco-vscode-host-service-override": "^33.0.9",
    "@codingame/monaco-vscode-keybindings-service-override": "^33.0.9",
    "@codingame/monaco-vscode-languages-service-override": "^33.0.9",
    "@codingame/monaco-vscode-layout-service-override": "^33.0.9",
    "@codingame/monaco-vscode-lifecycle-service-override": "^33.0.9",
    "@codingame/monaco-vscode-log-service-override": "^33.0.9",
    "@codingame/monaco-vscode-model-service-override": "^33.0.9",
    "@codingame/monaco-vscode-notifications-service-override": "^33.0.9",
    "@codingame/monaco-vscode-quickaccess-service-override": "^33.0.9",
    "@codingame/monaco-vscode-storage-service-override": "^33.0.9",
    "@codingame/monaco-vscode-textmate-service-override": "^33.0.9",
    "@codingame/monaco-vscode-theme-defaults-default-extension": "^33.0.9",
    "@codingame/monaco-vscode-theme-service-override": "^33.0.9",
    "@codingame/monaco-vscode-views-service-override": "^33.0.9",
    "@codingame/monaco-vscode-workbench-service-override": "^33.0.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.453.0",
    "mermaid": "^11.15.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^4.1.8"
  }
}
