{
  "name": "my-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Claude Code Terminal Center extension.",
  "scripts": {
    "build:renderer": "BUILD_TARGET=renderer vite build",
    "build:main": "BUILD_TARGET=main vite build",
    "build": "npm run build:renderer && npm run build:main",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": "^18"
  },
  "devDependencies": {
    "@cctc/extension-sdk": "*",
    "react": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8"
  }
}
